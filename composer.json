{
  "name": "biplane/yandex-direct",
  "type": "library",
  "description": "PHP library for Yandex.Direct API",
  "keywords": ["yandex", "yandex.direct", "Яндекс.Директ", "sdk"],
  "authors": [
    {
      "name": "Denis",
      "role": "Developer"
    },
    {
      "name": "Contributors",
      "homepage": "https://github.com/biplane/yandex-direct/graphs/contributors"
    }
  ],
  "license": "MIT",
  "require": {
    "php-64bit": "^8.3",
    "ext-libxml": "*",
    "ext-soap": "*",
    "php-http/discovery": "^1.14",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "symfony/options-resolver": "^6.4 || ^7.0 || ^8.0",
    "symfony/serializer": "^6.4 || ^7.0 || ^8.0"
  },
  "require-dev": {
    "allejo/php-vcr-sanitizer": "^1.1",
    "doctrine/coding-standard": "^14.0",
    "nyholm/psr7": "^1.8",
    "php-http/httplug": "^2.4",
    "php-vcr/php-vcr": "^1.8",
    "phpunit/phpunit": "^12.5.23",
    "psalm/plugin-phpunit": "^0.19.7",
    "psr/log": "^1.1",
    "symfony/http-client": "^6.4 || ^7.0 || ^8.0",
    "vimeo/psalm": "6.16.1"
  },
  "autoload": {
    "psr-4": { "Biplane\\YandexDirect\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": {
      "Biplane\\Tests\\YandexDirect\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "composer/package-versions-deprecated": true,
      "php-http/discovery": false
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "6.x-dev"
    }
  },
  "scripts": {
    "qa": [
      "@cs-check",
      "@analyse",
      "@test"
    ],
    "analyse": "psalm",
    "cs-check": "phpcs",
    "cs-fix": "phpcbf",
    "test": "phpunit --colors=always"
  }
}
