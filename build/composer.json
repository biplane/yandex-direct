{
  "name": "biplane/yandex-direct-build",
  "type": "project",
  "description": "Generate code",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "ext-libxml": "*",
    "ext-soap": "*",
    "laminas/laminas-code": "^4.17",
    "php-soap/wsdl-reader": "^0.31.0",
    "php-standard-library/php-standard-library": "^4.3",
    "symfony/console": "^7.4",
    "symfony/filesystem": "^7.4"
  },
  "require-dev": {
    "doctrine/coding-standard": "^14.0",
    "php-standard-library/psalm-plugin": "^2.4",
    "phpunit/phpunit": "^12.5",
    "psalm/plugin-phpunit": "^0.19.6",
    "rector/rector": "^2.4",
    "vimeo/psalm": "^6.16"
  },
  "autoload": {
    "psr-4": {
      "Biplane\\Build\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Biplane\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "qa": [
      "@cs-check",
      "@analyse",
      "@test"
    ],
    "analyse": "psalm",
    "cs-check": "phpcs",
    "cs-fix": "phpcbf",
    "test": "phpunit --colors=always"
  }
}
